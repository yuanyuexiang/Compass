# 复制为 .env 使用；backend 进程从项目根或 backend/ 目录读取
DATABASE_URL=postgresql+psycopg://compass:compass@localhost:5432/compass
REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=compass
MINIO_SECRET_KEY=compass-secret

# 本机代理做 HTTPS 中间人时置 false（仅开发环境）
# CRAWLER_VERIFY_SSL=false

# LLM（M2 启用）：DeepSeek，注意 2026-07-24 起旧模型名弃用，用 v4 系列
DEEPSEEK_API_KEY=
# Embedding（M2 启用）：SiliconFlow bge-m3
SILICONFLOW_API_KEY=
