# 生产环境配置：首次部署时复制为 /opt/compass/.env 并填写，不入 git。
# compose 拓扑相关变量（DATABASE_URL/REDIS_URL/MINIO_ENDPOINT）已在 compose 内固定，无需在此配置。

# 镜像坐标：给服务器上手动执行 compose 命令用（如种子脚本）；
# CI 部署时 deploy.sh 会以环境变量注入具体 sha 覆盖 TAG（shell 环境变量优先于本文件）
REGISTRY=registry.cn-hangzhou.aliyuncs.com
NAMESPACE=yuanyuexiang
TAG=latest

# 基础设施密钥（必填）
POSTGRES_PASSWORD=change-me
MINIO_ROOT_USER=compass
MINIO_ROOT_PASSWORD=change-me

# 认证（必填，换成随机长串）
JWT_SECRET=change-me-to-a-long-random-string

# LLM（必填）
DEEPSEEK_API_KEY=

# Embedding（可选；不填则匹配走二级漏斗）
SILICONFLOW_API_KEY=

# 采集：生产必须保持 true
CRAWLER_VERIFY_SSL=true

# Traefik（域名 compass.matrix-net.tech 已写死在 compose labels；
# 以下两项与你 Traefik 静态配置中的名字对齐，默认 websecure / letsencrypt）
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=aliyunresolver

# 邮件通知（可选）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
